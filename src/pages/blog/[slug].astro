---
import Layout from "@/layouts/Layout.astro";
import { getCollection, render } from "astro:content";
import { DATA } from "@/data/resume";
import { formatDate } from "@/lib/utils";
import { mdxComponents } from "@/mdx-components";
import { ChevronLeft } from "lucide-react";

export async function getStaticPaths() {
  const allPosts = await getCollection("blog");
  return allPosts.map((post) => ({
    params: { slug: String(post.data.postId) },
    props: {},
  }));
}

const slug = Astro.params.slug;
const postId = Number(slug);

const cookieLang = Astro.cookies.get("starfolio-language")?.value;
const currentLang = cookieLang === "en" ? "en" : "pt";

const allPosts = await getCollection("blog");
const post = allPosts.find((p) => p.data.postId === postId && p.data.lang === currentLang);

if (!post) {
  return Astro.redirect("/blog");
}

const { title, publishedAt, summary, image, lang } = post.data;
const postLang = lang === "en" ? "en" : "pt";

const allById = allPosts.filter((p) => p.data.postId === postId);
const otherLang = allById.find((p) => p.data.lang !== currentLang);
const otherTitle = otherLang?.data.title;

const { Content } = await render(post);

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  datePublished: publishedAt,
  dateModified: publishedAt,
  description: summary,
  image: image
    ? image.startsWith("http")
      ? image
      : `${DATA.url}${image}`
    : `${DATA.url}/og_image.png`,
  url: `${DATA.url}/blog/${slug}`,
  author: {
    "@type": "Person",
    name: DATA.name,
  },
}).replace(/</g, "\\u003c");
---

<Layout
  title={title}
  description={summary}
  image={image}
  canonicalURL={`${DATA.url}/blog/${slug}`}
>
  <section id="blog">
    <script is:inline type="application/ld+json" set:html={jsonLd} />
    <div class="flex justify-start gap-4 items-center">
      <a
        href="/blog"
        class="text-sm text-muted-foreground hover:text-foreground transition-colors border border-border rounded-lg px-2 py-1 inline-flex items-center gap-1 mb-6 group"
        aria-label={postLang === "pt" ? "Voltar para o blog" : "Back to blog"}
      >
        <ChevronLeft
          className="size-3 group-hover:-translate-x-px transition-transform"
        />
        {postLang === "pt" ? "Voltar para o blog" : "Back to blog"}
      </a>
    </div>
    <div class="flex flex-col gap-4">
      <h1
        class="title font-semibold text-3xl md:text-4xl tracking-tighter leading-tight"
      >
        {title}
      </h1>
      <p class="text-sm text-muted-foreground">
        {formatDate(publishedAt, postLang)}
      </p>
      {otherTitle ? (
        <p class="text-xs text-muted-foreground">
          {postLang === "pt" ? `Disponível também em inglês: ` : `Also available in Portuguese: `}
          <em>{otherTitle}</em>
        </p>
      ) : null}
    </div>
    <div class="my-6 flex w-full items-center">
      <div
        class="flex-1 h-px bg-border"
        style="mask-image: linear-gradient(90deg, transparent, black 8%, black 92%, transparent); -webkit-mask-image: linear-gradient(90deg, transparent, black 8%, black 92%, transparent);"
      >
      </div>
    </div>
    <article
      class="prose max-w-full text-pretty font-sans leading-relaxed text-muted-foreground dark:prose-invert"
    >
      <Content components={mdxComponents} />
    </article>
  </section>
</Layout>
