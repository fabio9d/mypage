---
const { term, lang } = Astro.props;
const theme = Astro.cookies.get("theme")?.value === "light" ? "light" : "dark";
const baseUrl = import.meta.env.BASE_URL;
---

<section class="mt-12 border-t border-border pt-8">
  <h2 class="text-lg font-semibold tracking-tight mb-4">
    {lang === "pt" ? "Comentários" : "Comments"}
  </h2>
  <script
    src="https://giscus.app/client.js"
    data-repo="fabio9d/mypage"
    data-repo-id="R_kgDOSx9-mQ"
    data-category="Announcements"
    data-category-id="DIC_kwDOSx9-mc4C-kd-"
    data-mapping="pathname"
    data-strict="0"
    data-reactions-enabled="1"
    data-emit-metadata="0"
    data-input-position="bottom"
    data-theme={theme}
    data-lang={lang === "pt" ? "pt" : "en"}
    crossorigin="anonymous"
    async
  ></script>
</section>
